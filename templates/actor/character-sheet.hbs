<form class="sw1e-sheet {{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}">
    <div class="header-fields">
      <div class="name-row">
        <input class="name-input" name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'SW1E.CharacterName'}}">
        <input name="system.identity.templateName" type="text" value="{{system.identity.templateName}}" placeholder="{{localize 'SW1E.Template'}}">
      </div>
      <div class="sheet-subtitle-row">
        <span class="sheet-subtitle">{{actorTypeLabel}}</span>
      </div>
      <div class="quick-actions-row">
        <button type="button" class="sw1e-roll-resistance quick-action">{{localize 'SW1E.Combat.ResistDamage'}}</button>
        <button type="button" class="sw1e-open-healing quick-action">{{localize 'SW1E.Healing.Open'}}</button>
        <button type="button" class="sw1e-open-advancement quick-action">{{localize 'SW1E.Advancement.Button'}}</button>
        <button type="button" class="sw1e-force-point quick-action {{#if forcePointActive}}is-active{{/if}}" data-force-point-action="{{forcePointButtonAction}}" {{#if forcePointButtonDisabled}}disabled{{/if}}>{{forcePointButtonLabel}}</button>
      </div>
      <div class="resource-grid four">
        <label>
          <span>{{localize 'SW1E.Species'}}</span>
          <input name="system.identity.species" type="text" value="{{system.identity.species}}">
        </label>
        <label>
          <span>{{localize 'SW1E.SkillPoints'}}</span>
          <input name="system.resources.skillPoints" type="number" value="{{system.resources.skillPoints}}" step="1">
        </label>
        <label>
          <span>{{localize 'SW1E.ForcePoints'}}</span>
          <input name="system.resources.forcePoints" type="number" value="{{system.resources.forcePoints}}" step="1">
        </label>
        <label>
          <span>{{localize 'SW1E.DarkSidePoints'}}</span>
          <input name="system.resources.darkSidePoints" type="number" value="{{system.resources.darkSidePoints}}" step="1">
        </label>
        <label>
          <span>{{localize 'SW1E.Credits'}}</span>
          <input name="system.resources.credits" type="number" value="{{system.resources.credits}}" min="0" step="1">
        </label>
        <label>
          <span>{{localize 'SW1E.Combat.ArmorBonusLabel'}}</span>
          <input type="text" value="{{#if hasArmorBonus}}{{armorBonusCode}}{{else}}{{localize 'SW1E.None'}}{{/if}}" disabled>
        </label>
        <label class="wound-field">
          <span>{{localize 'SW1E.WoundStatus'}}</span>
          <select name="system.status.woundStatus">
            {{#each woundStatuses as |status|}}
              <option value="{{status.key}}" {{#if (sw1eEq ../system.status.woundStatus status.key)}}selected{{/if}}>{{status.label}}</option>
            {{/each}}
          </select>
        </label>
      </div>
      {{#if forcePointStateLabel}}
        <div class="healing-summary">{{forcePointStateLabel}}</div>
      {{/if}}
      {{#if healingSummary}}
        <div class="healing-summary">{{healingSummary}}</div>
      {{/if}}
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="stats">{{localize 'SW1E.Tabs.Stats'}}</a>
    <a class="item" data-tab="equipment">{{localize 'SW1E.Tabs.Equipment'}}</a>
    <a class="item" data-tab="force">{{localize 'SW1E.Tabs.Force'}}</a>
    <a class="item" data-tab="notes">{{localize 'SW1E.Tabs.Notes'}}</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="stats">
      <section class="rules-note">
        <p>{{localize 'SW1E.Combat.RulesNote'}}</p>
      </section>

      <section class="attributes-grid">
        {{#each attributes as |attr|}}
          <article class="attribute-card">
            <header class="attribute-header">
              <button type="button" class="sw1e-roll-attribute" data-attribute="{{attr.key}}">{{attr.label}}</button>
              <span class="dice-code">{{attr.diceCode}}</span>
            </header>
            <div class="inline-fields">
              <label>
                <span>{{localize 'SW1E.Dice'}}</span>
                <input name="system.attributes.{{attr.key}}.dice" type="number" value="{{attr.dice}}" min="0" step="1">
              </label>
              <label>
                <span>{{localize 'SW1E.Pips'}}</span>
                <input name="system.attributes.{{attr.key}}.pips" type="number" value="{{attr.pips}}" min="0" max="2" step="1">
              </label>
            </div>
            <ol class="item-list skill-list">
              {{#each attr.skills as |skill|}}
                <li class="item flexrow" data-item-id="{{skill.id}}">
                  <button type="button" class="sw1e-roll-skill item-name">{{skill.name}}</button>
                  <span class="item-meta">{{skill.diceCode}}</span>
                  <div class="item-controls">
                    <a class="item-edit" title="{{localize 'SW1E.Edit'}}"><i class="fas fa-edit"></i></a>
                    <a class="item-delete" title="{{localize 'SW1E.Delete'}}"><i class="fas fa-trash"></i></a>
                  </div>
                </li>
              {{/each}}
            </ol>
            <button type="button" class="item-create add-button" data-type="skill" data-attribute="{{attr.key}}">{{localize 'SW1E.AddSkill'}}</button>
          </article>
        {{/each}}
      </section>

      {{#if unlinkedSkills.length}}
        <section class="orphan-section">
          <h3>{{localize 'SW1E.UnlinkedSkills'}}</h3>
          <ol class="item-list">
            {{#each unlinkedSkills as |skill|}}
              <li class="item flexrow" data-item-id="{{skill.id}}">
                <span class="item-name">{{skill.name}}</span>
                <div class="item-controls">
                  <a class="item-edit" title="{{localize 'SW1E.Edit'}}"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" title="{{localize 'SW1E.Delete'}}"><i class="fas fa-trash"></i></a>
                </div>
              </li>
            {{/each}}
          </ol>
        </section>
      {{/if}}
    </div>

    <div class="tab" data-group="primary" data-tab="equipment">
      <section class="list-section">
        <div class="section-header">
          <h3>{{localize 'SW1E.Equipment'}}</h3>
          <button type="button" class="item-create add-button" data-type="equipment">{{localize 'SW1E.AddEquipment'}}</button>
        </div>
        <ol class="item-list">
          {{#each equipment as |item|}}
            <li class="item flexrow" data-item-id="{{item.id}}">
              <div class="item-name two-line">
                <span>{{item.name}}</span>
                <span class="item-meta">{{localize (concat 'SW1E.EquipmentCategory.' item.category)}}{{#if item.showQuantity}} • ×{{item.quantity}}{{/if}}{{#if item.hasCost}} • {{item.cost}} {{localize 'SW1E.Credits'}}{{/if}}{{#if item.equipped}} • {{localize 'SW1E.Equipped'}}{{/if}}{{#if (sw1eEq item.category 'armor')}} • {{item.armorCode}}{{/if}}</span>
              </div>
              <div class="item-controls">
                <button type="button" class="item-toggle-equipped mini-button {{#if item.equipped}}is-active{{/if}}" title="{{localize 'SW1E.Equipped'}}" aria-pressed="{{item.equipped}}">
                  <i class="fas {{#if item.equipped}}fa-check-square{{else}}fa-square{{/if}}"></i>
                </button>
                <a class="item-edit" title="{{localize 'SW1E.Edit'}}"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="{{localize 'SW1E.Delete'}}"><i class="fas fa-trash"></i></a>
              </div>
            </li>
          {{/each}}
        </ol>
      </section>

      <section class="list-section">
        <div class="section-header">
          <h3>{{localize 'SW1E.Weapons'}}</h3>
          <button type="button" class="item-create add-button" data-type="weapon">{{localize 'SW1E.AddWeapon'}}</button>
        </div>
        <ol class="item-list">
          {{#each weapons as |item|}}
            <li class="item flexrow weapon-row" data-item-id="{{item.id}}">
              <div class="item-name two-line">
                <span>{{item.name}}</span>
                <span class="item-meta">{{item.damageCode}}{{#if item.skillUsed}} • {{item.skillUsed}}{{/if}}{{#if item.range}} • {{item.range}}{{/if}}{{#if item.hasCost}} • {{item.cost}} {{localize 'SW1E.Credits'}}{{/if}}</span>
              </div>
              <div class="item-controls action-controls">
                <button type="button" class="sw1e-weapon-attack mini-button">{{localize 'SW1E.Combat.Attack'}}</button>
                {{#if item.canLightsaberParry}}<button type="button" class="sw1e-lightsaber-parry mini-button">{{localize 'SW1E.Combat.LightsaberParry'}}</button>{{/if}}
                <button type="button" class="sw1e-weapon-damage mini-button">{{localize 'SW1E.Combat.Damage'}}</button>
                <a class="item-edit" title="{{localize 'SW1E.Edit'}}"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="{{localize 'SW1E.Delete'}}"><i class="fas fa-trash"></i></a>
              </div>
            </li>
          {{/each}}
        </ol>
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="force">
      <section class="rules-note">
        <p>{{forceRulesNote}}</p>
      </section>

      <section class="list-section force-skill-section">
        <div class="section-header">
          <h3>{{localize 'SW1E.Force.Title'}}</h3>
          <span class="item-meta">{{localize 'SW1E.Force.KeptUpPowers'}}: {{activeForceSkillCount}}</span>
        </div>
        <div class="force-skill-grid">
          {{#each forceSkills as |skill|}}
            <article class="force-skill-card {{#unless skill.trained}}untrained{{/unless}}">
              <header class="attribute-header">
                <button type="button" class="sw1e-roll-force-skill" data-force-skill="{{skill.key}}">{{skill.label}}</button>
                <span class="dice-code">{{skill.diceCode}}</span>
              </header>
              <div class="inline-fields">
                <label>
                  <span>{{localize 'SW1E.Dice'}}</span>
                  <input name="system.force.{{skill.key}}.dice" type="number" value="{{skill.dice}}" min="0" step="1">
                </label>
                <label>
                  <span>{{localize 'SW1E.Pips'}}</span>
                  <input name="system.force.{{skill.key}}.pips" type="number" value="{{skill.pips}}" min="0" max="2" step="1">
                </label>
              </div>
              {{#unless skill.trained}}
                <p class="empty-note">{{localize 'SW1E.Force.UntrainedShort'}}</p>
              {{/unless}}
            </article>
          {{/each}}
        </div>
        <div class="notes-grid compact top-gap">
          <label>
            <span>{{localize 'SW1E.Force.Teacher'}}</span>
            <input name="system.force.teacher" type="text" value="{{system.force.teacher}}">
          </label>
          <label class="full-width">
            <span>{{localize 'SW1E.Force.TrainingNotes'}}</span>
            <textarea name="system.force.trainingNotes">{{system.force.trainingNotes}}</textarea>
          </label>
          <label class="full-width">
            <span>{{localize 'SW1E.Force.CodeNotes'}}</span>
            <textarea name="system.force.codeNotes">{{system.force.codeNotes}}</textarea>
          </label>
        </div>
      </section>

      <section class="list-section top-gap">
        <div class="section-header">
          <h3>{{localize 'SW1E.Force.Powers'}}</h3>
          <button type="button" class="item-create add-button" data-type="forcePower">{{localize 'SW1E.Force.AddPower'}}</button>
        </div>
        <ol class="item-list">
          {{#each forcePowers as |item|}}
            <li class="item flexrow force-power-row" data-item-id="{{item.id}}">
              <div class="item-name three-line">
                <span>{{item.name}}</span>
                <span class="item-meta">{{item.requirementLabel}}</span>
                <span class="item-meta">{{item.difficultySummary}}{{#if item.sourcePage}} • {{localize 'SW1E.SourcePage'}} {{item.sourcePage}}{{/if}}</span>
              </div>
              <div class="item-controls action-controls">
                {{#if item.darkSideWarning}}<span class="warning-tag">{{localize 'SW1E.Warning'}}</span>{{/if}}
                {{#if item.keepUp}}
                  <button type="button" class="sw1e-force-toggle mini-button">{{#if item.isUp}}{{localize 'SW1E.Force.DropPower'}}{{else}}{{localize 'SW1E.Force.MarkUp'}}{{/if}}</button>
                {{/if}}
                <button type="button" class="sw1e-force-use mini-button">{{localize 'SW1E.Force.Activate'}}</button>
                <a class="item-edit" title="{{localize 'SW1E.Edit'}}"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="{{localize 'SW1E.Delete'}}"><i class="fas fa-trash"></i></a>
              </div>
            </li>
          {{/each}}
        </ol>
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="notes">
      <section class="notes-grid">
        <label>
          <span>{{localize 'SW1E.Sex'}}</span>
          <input name="system.identity.sex" type="text" value="{{system.identity.sex}}">
        </label>
        <label>
          <span>{{localize 'SW1E.Age'}}</span>
          <input name="system.identity.age" type="text" value="{{system.identity.age}}">
        </label>
        <label>
          <span>{{localize 'SW1E.Height'}}</span>
          <input name="system.identity.height" type="text" value="{{system.identity.height}}">
        </label>
        <label>
          <span>{{localize 'SW1E.Weight'}}</span>
          <input name="system.identity.weight" type="text" value="{{system.identity.weight}}">
        </label>
        <label class="full-width">
          <span>{{localize 'SW1E.PhysicalDescription'}}</span>
          <textarea name="system.identity.physicalDescription">{{system.identity.physicalDescription}}</textarea>
        </label>
        <label class="full-width">
          <span>{{localize 'SW1E.Personality'}}</span>
          <textarea name="system.identity.personality">{{system.identity.personality}}</textarea>
        </label>
        <label class="full-width">
          <span>{{localize 'SW1E.Objectives'}}</span>
          <textarea name="system.identity.objectives">{{system.identity.objectives}}</textarea>
        </label>
        <label class="full-width">
          <span>{{localize 'SW1E.Quote'}}</span>
          <textarea name="system.identity.quote">{{system.identity.quote}}</textarea>
        </label>
        <label class="full-width">
          <span>{{localize 'SW1E.Background'}}</span>
          <textarea name="system.identity.background">{{system.identity.background}}</textarea>
        </label>
        <label class="full-width">
          <span>{{localize 'SW1E.DefenseNotes'}}</span>
          <textarea name="system.status.defenseNotes">{{system.status.defenseNotes}}</textarea>
        </label>
        <label class="full-width">
          <span>{{localize 'SW1E.ActionPenaltyNotes'}}</span>
          <textarea name="system.status.actionPenaltyNotes">{{system.status.actionPenaltyNotes}}</textarea>
        </label>
        <label class="full-width">
          <span>{{localize 'SW1E.StoryNotes'}}</span>
          <textarea name="system.notes.storyNotes">{{system.notes.storyNotes}}</textarea>
        </label>
        <label class="full-width">
          <span>{{localize 'SW1E.GamemasterNotes'}}</span>
          <textarea name="system.notes.gamemasterNotes">{{system.notes.gamemasterNotes}}</textarea>
        </label>
      </section>
    </div>
  </section>
</form>
